# ============================================================
# Grounded API — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# Node environment: development | test | production
NODE_ENV=development

# Port the Express server listens on.
PORT=3001

# ── Database ────────────────────────────────────────────────
# Supabase provides two connection strings:
#   DATABASE_URL       — the connection pooler URL (use for app queries)
#   DATABASE_DIRECT_URL — direct connection (use for Prisma migrations only)
#
# Find both in Supabase → Project Settings → Database → Connection string
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DATABASE_DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-2.pooler.supabase.com:5432/postgres"

# ── Supabase Auth ────────────────────────────────────────────
# Found in Supabase → Project Settings → API
SUPABASE_URL="https://[project-ref].supabase.co"
# The anon key is safe to use server-side for auth.getUser() verification.
SUPABASE_ANON_KEY="eyJ..."
# Service role key — has full database access, bypasses RLS.
# Used for admin operations only (e.g. creating a user record after signup).
# KEEP THIS SECRET. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ── Mapbox ───────────────────────────────────────────────────
# Secret access token for server-side Mapbox Tilequery API calls.
# We proxy Mapbox requests through the API to keep this token secret.
# The public token used in the browser is in apps/web/.env
MAPBOX_SECRET_TOKEN="sk.eyJ..."

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production: https://app.grounded.io
# In development: http://localhost:5173
ALLOWED_ORIGINS="http://localhost:5173"

{
  "name": "@grounded/api",
  "version": "0.0.1",
  "private": true,
  "description": "Grounded v2 tRPC API server — Node.js + Express",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "main": "./dist/index.js",
  "types": "./dist/router.d.ts",
  "exports": {
    ".": {
      "types": "./dist/router.d.ts"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@grounded/db": "workspace:*",
    "@grounded/types": "workspace:*",
    "@supabase/supabase-js": "^2.48.1",
    "@trpc/server": "^11.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "lru-cache": "^11.2.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@grounded/config": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^3.0.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.2"
  }
}

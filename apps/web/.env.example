# ============================================================
# Grounded Web — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# URL of the Grounded API server.
# In development: http://localhost:3001 (proxied via Vite — use /api in components)
# In production: https://api.grounded.io
VITE_API_URL=http://localhost:3001

# Supabase project settings — found in Supabase → Project Settings → API
# These are SAFE to expose in the browser (they're public by design).
VITE_SUPABASE_URL="https://[project-ref].supabase.co"
VITE_SUPABASE_ANON_KEY="eyJ..."

# Mapbox PUBLIC access token — for rendering map tiles in the browser.
# Restrict this token in Mapbox dashboard to your domain only.
# Set scopes to: styles:read, tiles:read (NOT tilequery — that stays server-side)
VITE_MAPBOX_PUBLIC_TOKEN="pk.eyJ..."

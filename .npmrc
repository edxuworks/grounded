# Hoist Prisma binaries and Mapbox packages to root node_modules
# Required for Prisma CLI and react-map-gl peer deps to resolve correctly
public-hoist-pattern[]=*prisma*
public-hoist-pattern[]=*@mapbox*
public-hoist-pattern[]=*mapbox-gl*

# Ensure lockfile is always up to date
strict-peer-dependencies=false
auto-install-peers=true

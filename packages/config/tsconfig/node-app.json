{
  "$schema": "https://json.schemastore.org/tsconfig",
  // Extends the base config with Node.js-specific settings.
  // Used by apps/api — adds Node types, removes DOM libs.
  "extends": "./base.json",
  "compilerOptions": {
    // Node 20+ supports all ES2022 features natively without transpilation.
    "lib": ["ES2022"],
    // CommonJS output for Node.js compatibility with Express and most npm
    // packages. Can be changed to ESNext if we move to native ESM + tsx.
    "module": "CommonJS",
    // For CommonJS modules, "node" resolution is more reliable than "bundler".
    "moduleResolution": "node",
    // @types/node provides Node.js built-in typings (fs, path, process, etc.)
    "types": ["node"]
  }
}

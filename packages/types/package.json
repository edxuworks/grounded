{
  "name": "@grounded/types",
  "version": "0.0.1",
  "private": true,
  "description": "Shared Zod schemas and TypeScript types used by both apps/api and apps/web",
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "dependencies": {


    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@grounded/config": "workspace:*",
    "typescript": "^5.7.3"
  }
}
